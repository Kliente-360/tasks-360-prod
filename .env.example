# Copie pra .env.local para desenvolvimento local.
# Em produção (Vercel) a integração Supabase-Vercel injeta POSTGRES_URL,
# SUPABASE_URL e SUPABASE_ANON_KEY automaticamente.
# As duas vars NEXT_PUBLIC_ precisam ser adicionadas manualmente no Vercel
# (copiar os valores de SUPABASE_URL e SUPABASE_ANON_KEY).

# Supabase — exposto ao browser (prefixo NEXT_PUBLIC_ obrigatório).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Drizzle — server-side apenas, NUNCA expor ao client.
# Em dev local: Transaction pooler porta 6543 (mesma string do Vercel POSTGRES_URL).
DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres
